      "type": "timeseries",
      "title": "API Requests per Second",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(galaxy_api_requests_total[1m]))",
