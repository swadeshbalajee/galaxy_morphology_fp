      "title": "Postgres Log Records",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "targets": [
        {
          "expr": "sum(galaxy_service_logs_total) by (service, component)",
          "legendFormat": "{{service}} / {{component}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "type": "logs",
      "title": "API Logs",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT created_at AS \"time\", concat(service, ' | ', level, ' | ', component, ' | ', message, COALESCE(E'\\n' || NULLIF(exception, ''), '')) AS \"line\", service, component, level FROM service_logs WHERE $__timeFilter(created_at) AND service = 'api' ORDER BY created_at DESC LIMIT 500",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
