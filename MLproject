
name: galaxy-mlops

python_env: requirements/mlflow_env.yaml

entry_points:
  fetch_raw:
    command: "python -m src.data.download_galaxy_zoo"

  preprocess_v1:
    command: "python -m src.data.preprocess_v1"

  preprocess_final:
    command: "python -m src.data.preprocess_final"

  train:
    command: "python -m src.training.train"

  evaluate:
    command: "python -m src.training.evaluate"

  report:
    command: "python -m src.reporting.generate_report"
